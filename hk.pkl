amends "package://github.com/jdx/hk/releases/download/v1.48.0/hk@1.48.0#/Config.pkl"
import "package://github.com/jdx/hk/releases/download/v1.48.0/hk@1.48.0#/Builtins.pkl"

local lintSteps = new Mapping<String, Step> {
    ["cargo-check"] {
        glob = List("**/*.rs", "Cargo.toml", "Cargo.lock")
        check = "cargo check --workspace"
    }
    ["cargo-check-wasm"] {
        glob = List("**/*.rs", "Cargo.toml", "Cargo.lock")
        check = "cargo check --target wasm32-unknown-unknown --package jolt_text --package jolt_formatter --package jolt_fmt_ir --package jolt_syntax --package jolt_java_syntax --package jolt_java_fmt --package jolt_fmt_dprint --features jolt_fmt_dprint/wasm"
    }
    ["cargo-clippy"] {
        glob = List("**/*.rs")
        check = "cargo clippy --workspace -- -D warnings"
    }
    ["cargo-machete"] {
        glob = List("**/*.rs", "Cargo.toml", "Cargo.lock")
        check = "cargo machete"
        fix = "cargo machete --fix"
    }
    ["dprint"] = (Builtins.dprint) {
        exclude = List("**/*.snap", "fixtures/java/**", "fixtures/kotlin/**")
    }
}

hooks {
    ["pre-commit"] {
        fix = true
        stash = "git"
        steps = lintSteps
    }
    ["fix"] {
        fix = true
        steps = lintSteps
    }
    ["check"] {
        steps = lintSteps
    }
}
