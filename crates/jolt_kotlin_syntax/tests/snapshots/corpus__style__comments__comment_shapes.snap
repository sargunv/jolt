//
val value=1
}

fun singleEmptyBlock() { /**/ }

fun singleStarDoc() { /*****/ }

fun singleNestedBlock() { /* outer /* inner */ outer */ }

fun singleLine() { //
}

fun call(vararg values: Any?) {}
