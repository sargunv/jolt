input:
fun typeArguments(a: Int, b: Int, c: Int) {
    val parsed = factory.create<List<String>, Map<String, Int>>(emptyList(), emptyMap())
    val compared = a < b && b > c
    val spaced = value < other > fallback
    sink(parsed, compared, spaced)
}

