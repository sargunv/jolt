fun trailing(values: List<Int>) {
  values
    .map { it + 1 }
    .filter({ value -> value > 2 })
    .fold(0) { acc, value -> acc + value }
}

class Cached<T>(private val init: (Int) -> T) {
  init {
    require(true)
  }

  private val values = List(8) { init(it) }
}

