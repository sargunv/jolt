            // ...
        }
    }

    void chainFitsButLastDotPastReviewLimit() {
        var foo =
            SomeType.builder()
                .thing1(thing1)
                .thing2(thing2)
                .thing3(thing3)
                .build();
    }

    void chainSplitByReviewLimit() {
