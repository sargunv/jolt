  }

  public Map<FooBarRid, BazQuxMetrics> otherMethod(
    FooAuthHeader authHeader,
    Set<FooBarRid> thingRids,
    WidgetTimeRange timeRange
  ) {
    return myCustomService.get()
      .fetchData(authHeader, FooMyCustomClass.of(thingRids, timeRange))
      .entrySet()
      .stream()
      .collect(
        Collectors.toMap(
          Map.Entry::getKey,
          entry -> entry.getValue().getMetrics()
        )
      );
  }
}
