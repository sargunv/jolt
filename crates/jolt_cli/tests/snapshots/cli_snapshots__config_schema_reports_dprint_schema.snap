  "definitions": {
    "FormatOptions": {
      "description": "Formatter options shared by CLI and dprint.",
      "type": "object",
      "properties": {
        "indentWidth": {
          "description": "Number of spaces per indentation level when `use_tabs` is false.",
          "type": "integer",
          "format": "uint8",
          "maximum": 255.0,
          "minimum": 1.0
        },
        "lineWidth": {
          "description": "Preferred maximum rendered line width.",
          "type": "integer",
          "format": "uint16",
          "maximum": 65535.0,
          "minimum": 1.0
        },
        "useTabs": {
          "description": "Whether indentation should use tabs instead of spaces.",
          "type": "boolean"
        }
