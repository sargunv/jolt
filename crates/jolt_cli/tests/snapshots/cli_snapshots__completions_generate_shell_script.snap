                ;;
            jolt__subcmd__config__subcmd__help,schema)
                cmd="jolt__subcmd__config__subcmd__help__subcmd__schema"
                ;;
            jolt__subcmd__help,completions)
                cmd="jolt__subcmd__help__subcmd__completions"
                ;;
            jolt__subcmd__help,config)
                cmd="jolt__subcmd__help__subcmd__config"
                ;;
            jolt__subcmd__help,format)
