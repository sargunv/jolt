_jolt() {
    local i cur prev opts cmd
    COMPREPLY=()
    if [[ "${BASH_VERSINFO[0]}" -ge 4 ]]; then
        cur="$2"
    else
        cur="${COMP_WORDS[COMP_CWORD]}"
    fi
    prev="$3"
    cmd=""
    opts=""

    for i in "${COMP_WORDS[@]:0:COMP_CWORD}"
    do
        case "${cmd},${i}" in
            ",$1")
                cmd="jolt"
                ;;
            jolt,completions)
                cmd="jolt__subcmd__completions"
                ;;
            jolt,config)
                cmd="jolt__subcmd__config"
                ;;
            jolt,fmt)
                cmd="jolt__subcmd__format"
                ;;
            jolt,format)
                cmd="jolt__subcmd__format"
                ;;
            jolt,help)
                cmd="jolt__subcmd__help"
                ;;
            jolt,manpage)
                cmd="jolt__subcmd__manpage"
                ;;
            jolt__subcmd__config,help)
                cmd="jolt__subcmd__config__subcmd__help"
                ;;
            jolt__subcmd__config,init)
                cmd="jolt__subcmd__config__subcmd__init"
                ;;
            jolt__subcmd__config,list)
                cmd="jolt__subcmd__config__subcmd__list"
                ;;
            jolt__subcmd__config,resolve)
                cmd="jolt__subcmd__config__subcmd__resolve"
                ;;
            jolt__subcmd__config,schema)
                cmd="jolt__subcmd__config__subcmd__schema"
                ;;
            jolt__subcmd__config__subcmd__help,help)
