.el .ds Aq '
.TH jolt-completions 1  "jolt 0.20260705.0 ($COMMIT)" "Jolt Manual"
.SH NAME
jolt\-completions \- Generate shell completions
.SH SYNOPSIS
\fBjolt completions\fR [\fB\-h\fR|\fB\-\-help\fR] <\fISHELL\fR> 
.SH DESCRIPTION
Generate shell completions
.SH OPTIONS
.TP
\fB\-h\fR, \fB\-\-help\fR
Print help
.TP
<\fISHELL\fR>
Shell to generate completions for
.br

.br
\fIPossible values:\fR
.RS 14
.IP \(bu 2
bash
.IP \(bu 2
elvish
.IP \(bu 2
fish
.IP \(bu 2
powershell
.IP \(bu 2
zsh
.RE
