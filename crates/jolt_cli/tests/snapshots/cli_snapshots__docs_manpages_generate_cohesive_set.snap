-- jolt-format.1 --
.ie \n(.g .ds Aq \(aq
.el .ds Aq '
.TH jolt-format 1  "jolt 0.20260705.0 ($COMMIT)" "Jolt Manual"
.SH NAME
jolt\-format \- Format source files
.SH SYNOPSIS
\fBjolt format\fR [\fB\-\-check\fR] [\fB\-\-line\-width\fR] [\fB\-\-indent\-width\fR] [\fB\-\-use\-tabs\fR] [\fB\-\-include\fR] [\fB\-\-exclude\fR] [\fB\-\-config\fR] [\fB\-\-no\-config\fR] [\fB\-\-stdin\-filename\fR] [\fB\-\-threads\fR] [\fB\-h\fR|\fB\-\-help\fR] [\fIPATHS\fR] 
.SH DESCRIPTION
Format source files
.SH OPTIONS
.TP
\fB\-\-check\fR
Check whether files are formatted without writing changes
.TP
\fB\-\-line\-width\fR \fI<LINE_WIDTH>\fR
Preferred maximum rendered line width
.TP
\fB\-\-indent\-width\fR \fI<INDENT_WIDTH>\fR
Number of spaces per indentation level when using spaces
.TP
\fB\-\-use\-tabs\fR \fI<USE_TABS>\fR
Whether to use tabs for indentation
.br

.br
\fIPossible values:\fR
.RS 14
.IP \(bu 2
true
.IP \(bu 2
false
.RE
.TP
\fB\-\-include\fR \fI<INCLUDE>\fR
Include source files matching this glob
.TP
\fB\-\-exclude\fR \fI<EXCLUDE>\fR
Exclude source files matching this glob
.TP
\fB\-\-config\fR \fI<CONFIG>\fR
Load only this explicit config file
.TP
\fB\-\-no\-config\fR
Disable discovered project configs
.TP
\fB\-\-stdin\-filename\fR \fI<STDIN_FILENAME>\fR
Path\-like name used for stdin language detection and diagnostics
.TP
\fB\-\-threads\fR \fI<THREADS>\fR
Number of formatter worker threads to use for filesystem paths
.TP
\fB\-h\fR, \fB\-\-help\fR
Print help
.TP
[\fIPATHS\fR]
Files or directories to format. Use \*(Aq\-\*(Aq to read stdin
