{
  "format_on_save": "on",
  "formatter": {
    "external": {
      "command": "mise",
      "arguments": [
        "x",
        "--silent",
        "--",
        "dprint",
        "fmt",
        "--stdin",
        "{buffer_path}"
      ]
    }
  },
  "file_scan_exclusions": [".git", "tools/import/.imports"]
}
